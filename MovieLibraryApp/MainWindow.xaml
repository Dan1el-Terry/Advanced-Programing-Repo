<Window x:Class="MovieLibraryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movie Library" Height="500" Width="800">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- INPUT -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

            <TextBox x:Name="IdBox" Width="80" Margin="5"/>
            <TextBox x:Name="TitleBox" Width="120" Margin="5"/>
            <TextBox x:Name="DirectorBox" Width="120" Margin="5"/>
            <TextBox x:Name="GenreBox" Width="100" Margin="5"/>
            <TextBox x:Name="YearBox" Width="80" Margin="5"/>

            <Button Content="Add Movie" Width="100" Margin="10,5"
                    Click="AddMovie_Click"/>

        </StackPanel>

        <!-- TABLE -->
        <DataGrid x:Name="MovieGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>

    </Grid>
</Window>